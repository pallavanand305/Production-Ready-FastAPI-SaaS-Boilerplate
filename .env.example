# Application
PROJECT_NAME="FastAPI SaaS Boilerplate"
VERSION="1.0.0"
API_V1_STR="/api/v1"
DEBUG=false
ENVIRONMENT="development"

# Security
SECRET_KEY="your-secret-key-here-change-in-production-use-openssl-rand-hex-32"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM="HS256"
BCRYPT_ROUNDS=12

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastapi_saas"
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO=false

# Redis
REDIS_URL="redis://localhost:6379/0"
CACHE_DEFAULT_TTL=300

# Celery
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_PREMIUM_REQUESTS=1000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL="INFO"

# AWS (for production deployment)
AWS_REGION="us-east-1"
AWS_SECRETS_MANAGER_SECRET_NAME="fastapi-saas/prod"

# Request Size Limit (in bytes)
MAX_REQUEST_SIZE=10485760

# Account Lockout
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
